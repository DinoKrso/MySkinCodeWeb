{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SkincodeImageUploads",
      "Effect": "Allow",
      "Action": ["s3:PutObject", "s3:GetObject"],
      "Resource": "arn:aws:s3:::skincode-image-uploads/*"
    },
    {
      "Sid": "ProductsImagesSkincode",
      "Effect": "Allow",
      "Action": ["s3:PutObject", "s3:GetObject"],
      "Resource": "arn:aws:s3:::products-images-skincode/*"
    }
  ]
}
