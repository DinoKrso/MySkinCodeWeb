# Password reset (server-side only — nikad u VITE_* prefiks; obavezno na Vercelu)
RESEND_API_KEY=
RESEND_FROM=MySkinCode <noreply@myskincodeapp.com>
# Produkcija: postavi na https://www.myskincodeapp.com (na Vercelu Production env)
# Lokalno: http://localhost:5173 — na produkciji localhost u APP_BASE_URL se ignorira
APP_BASE_URL=https://www.myskincodeapp.com
PASSWORD_RESET_JWT_SECRET=
RESET_PASSWORD_API_URL=https://ai8hjf2fsc.execute-api.eu-central-1.amazonaws.com/dev/reset-password
